{
    "name": "trikivr",
    "version": "0.1.0",
    "description": "Middleware that turns Żabka Triki BLE gadgets into SlimeVR full-body trackers",
    "type": "module",
    "main": "dist/main.js",
    "author": "CreoleVR",
    "license": "MIT",
    "scripts": {
        "rebuild": "electron-rebuild -f -o @stoprocent/noble,@stoprocent/bluetooth-hci-socket",
        "setup:linux": "bash scripts/setup-linux-ble.sh",
        "build": "del-cli dist/ && tsc && npm run copy-files",
        "copy-files": "copyfiles -u 1 \"src/static/**/*\" dist/",
        "start": "npm run build && electron . --no-sandbox",
        "test": "tsc -p tsconfig.test.json && node --test \"dist-test/**/*.test.js\"",
        "lint": "eslint \"src/**/*.ts\""
    },
    "dependencies": {
        "@slimevr/common": "^0.1.3",
        "@slimevr/firmware-protocol": "^0.6.6",
        "@slimevr/tracker-emulation": "^0.2.6",
        "@stoprocent/noble": "^2.3.4"
    },
    "devDependencies": {
        "@electron/rebuild": "^3.7.2",
        "@types/node": "^24.9.1",
        "copyfiles": "^2.4.1",
        "del-cli": "^7.0.0",
        "electron": "^37.7.1",
        "typescript": "^5.9.3"
    }
}
